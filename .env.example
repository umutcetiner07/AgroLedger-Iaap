# =============================================================
# AgroLedger-Iaap — Ortam Değişkenleri Şablonu
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# FIX (P0): Güvenli şablon oluşturuldu; gerçek secret .env'de kalır.
# =============================================================

# Neon PostgreSQL bağlantısı — Neon panosundan alın
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require&channel_binding=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require"

# NextAuth gizli anahtarı — openssl rand -base64 32 ile üretin
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_-base64_32"
NEXTAUTH_URL="http://localhost:3000"

# Cron endpoint koruma anahtarı — openssl rand -base64 32 ile üretin
# Vercel Cron kullanılıyorsa bu değeri Vercel Environment Variables'a da ekleyin
CRON_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_-base64_32"
