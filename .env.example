# =============================================================
# BerekeAI — AgroLedger Modülü
# Ortam Değişkenleri Şablonu
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# =============================================================

# ─────────────────────────────────────────────────────────────
# VERİTABANI
# Neon PostgreSQL bağlantısı — Neon panosundan alın
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─────────────────────────────────────────────────────────────
# NEXTAUTH — Kimlik Doğrulama
# openssl rand -base64 32 ile üretin
# ─────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_-base64_32"
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────
# CRON — Zamanlanmış Görevler
# openssl rand -base64 32 ile üretin
# Vercel Cron kullanılıyorsa Vercel Environment Variables'a da ekleyin
# ─────────────────────────────────────────────────────────────
CRON_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_-base64_32"

# ─────────────────────────────────────────────────────────────
# HARİCA APİ'LER (Road :dot:
